```gitignore
# =========================
# Environment Variables
# =========================
backend/.env.backend
.env.db
.env

# =========================
# Python (Backend)
# =========================
backend/__pycache__/
backend/*.py[cod]
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/.coverage
backend/htmlcov/
backend/.venv/
backend/venv/
backend/env/

# =========================
# React / Vite (Frontend)
# =========================
frontend/node_modules/
frontend/dist/
frontend/.vite/

# =========================
# Logs
# =========================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# IDE
# =========================
.vscode/
.idea/

# =========================
# Operating System
# =========================
.DS_Store
Thumbs.db

# =========================
# Python
# =========================
*.pyc
*.pyo
*.pyd

# =========================
# Temporary / Cache
# =========================
.cache/
coverage/
*.swp
*.bak
*.tmp

# =========================
# Docker
# =========================
*.pid
```
